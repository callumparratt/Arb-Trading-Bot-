# Copy to ".env" (gitignored) and fill in. python-dotenv loads it automatically.
# Every value here is a SECRET — never commit the real .env.

# --- Async Discord alerting -------------------------------------------------
# Create a webhook: Discord → Server Settings → Integrations → Webhooks → New.
# When this is set, the bot pushes circuit-breaker trips, leg-out liquidations,
# an hourly trade/PnL summary, and online/offline events to that channel.
# Leave it unset to run with alerting disabled (the bot behaves identically).
DISCORD_WEBHOOK_URL=

# --- Exchange API credentials (ONLY needed for --live / dry_run=false) ------
# The public order-book streams need no auth; these are consumed solely by the
# authenticated reconciliation layer. Simulation (the default) ignores them.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
